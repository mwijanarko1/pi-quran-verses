  "type": "module",
  "description": "Pi extension that shows complete-sentence Quran verses in the working spinner, with multi-language translation settings.",
  "license": "MIT",
  "author": "mwijanarko1",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mwijanarko1/pi-quran-verses.git"
  },
