    "url": "https://github.com/mwijanarko1/pi-quran-verses/issues"
  },
  "homepage": "https://github.com/mwijanarko1/pi-quran-verses#readme",
  "keywords": [
    "pi-package",
    "pi",
    "pi-coding-agent",
    "quran",
    "extension"
  ],
  "files": [
    "extensions",
    "README.md",
    "LICENSE"
  ],
